# Runtime
AUDITX_ENV=development
AUDITX_LOG_LEVEL=INFO

# Backend
AUDITX_API_HOST=127.0.0.1
AUDITX_API_PORT=8765
AUDITX_STORAGE_DIR=.data

# LLM placeholders - do not commit real secrets
AUDITX_LLM_PROVIDER=none
AUDITX_LLM_MODEL=
AUDITX_LLM_API_KEY=

# OCR placeholders
AUDITX_OCR_PROVIDER=none

# uv
UV_CACHE_DIR=.uv-cache
